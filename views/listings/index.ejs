<% layout("/layouts/boilerplate")%>
<body>
    <h3>All Listings</h3>
    <!--     <form method="GET" action="/listings/new">
        <button> Create new Listing </button>
    </form>  -->    
    <!--As it was not required after words-->
    <div class="row row-cols-lg-3 row-cols-md-2 row-col-sm-1"><!--minimum 3 cards in a row in large -->
    <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card col" >
                <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image" style="height: 20rem"/>
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %></b><br/>
                        &#8377;<%= listing.price.toLocaleString("en-IN") %>
                    </p>
                </div>
            </div>
        </a>
    <% } %>
    </div>
    
<!--was used while making database work and to form intial backend path and checking them if they are working correctly 
     <ul>
        <% for(let listing of allListings) { %>
            <li><a href="/listings/<%= listing._id %>"> <%= listing.title %></li>
        <% } %>
    </ul>  
    -->  
</body>